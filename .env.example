# ── Copy to .env.local for local dev, or set in Vercel → Settings → Environment Variables ──
# Your OpenAI API key (required). Never commit the real key.
OPENAI_API_KEY=sk-your-key-here
# Model: gpt-4o = sharper, fewer hallucinations (recommended for medical). gpt-4o-mini = cheaper.
OPENAI_MODEL=gpt-4o

# PostgreSQL connection string (monorepo API server only — not needed for Phase 1 / Vercel deploy)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
